as.data.frame(mat$outputMatrix)
})
combinedData <- bind_rows(dfs)
colnames(combinedData) <- c(
"subject", "conditionUsed", "block", "trial", "repetition",
"context", "contextCode", "primaryColor", "secondaryColor",
"angle1", "initiation_time1", "movement_time1", "rt1",
"angle2", "initiation_time2", "movement_time2", "rt2",
"breakTaken", "conditions"
)
### PREPROCESSING ----
dependent_variable <- "angle1"
rt_vars <- c("rt1", "rt2")
combinedData_sub <- combinedData %>%
mutate(
DV = abs(.data[[dependent_variable]]),
subject = factor(subject),
repetition = factor(repetition, levels = c(1,5), labels = c("1","5")),
context = factor(context, levels = c(0,1), labels = c("No Change","Change"))
) %>%
filter(is.finite(DV)) %>%
filter(repetition %in% c("1","5"),
context %in% c("No Change","Change"))
# ---- Subject-level outlier exclusion ----
subject_means <- combinedData_sub %>%
group_by(subject) %>%
summarize(mean_DV = mean(DV, na.rm = TRUE), .groups = "drop")
grand_mean <- mean(subject_means$mean_DV, na.rm = TRUE)
grand_sd   <- sd(subject_means$mean_DV, na.rm = TRUE)
bad_subjects <- subject_means %>%
filter(abs(mean_DV - grand_mean) > 2.5 * grand_sd)
combinedData_sub <- combinedData_sub %>%
filter(!(subject %in% bad_subjects$subject))
### RM-ANOVA (PRIMARY ANALYSIS) ----
afex_options(type = 3, check_contrasts = TRUE)
data_RMAnova <- combinedData_sub %>%
group_by(subject, repetition, context) %>%
summarize(mean_DV = mean(DV, na.rm = TRUE), .groups = "drop")
descriptives <- data_RMAnova %>%
group_by(repetition, context) %>%
summarize(
mean = mean(mean_DV),
sd = sd(mean_DV),
n_subj = n(),
se = sd / sqrt(n_subj),
.groups="drop"
)
aov_mod <- aov_ez(
id     = "subject",
dv     = "mean_DV",
within = c("repetition", "context"),
data   = data_RMAnova,
type   = 3
)
anova_tbl <- anova(aov_mod)
### ESTIMATED MARGINAL MEANS ----
emm <- emmeans(aov_mod, ~ repetition * context)
# Simple effects for interaction
simple_effects <- contrast(
emmeans(aov_mod, ~ context | repetition),
method = "pairwise",
adjust = "holm"
)
### VISUALIZATION ----
emm_df <- as.data.frame(summary(emm, infer = TRUE))
p <- ggplot(emm_df,
aes(x = repetition, y = emmean,
color = context, group = context)) +
geom_point(size = 3) +
geom_line(linewidth = 1) +
geom_errorbar(aes(ymin = lower.CL, ymax = upper.CL), width = .15) +
labs(y = "Estimated Mean Angle Error",
x = "Repetition",
color = "Context",
title = "Repetition × Context Interaction") +
theme_classic(base_size = 15)
print(p)
### ROBUSTNESS CHECK: LMM for RTs, Gamma GLMM for Angles ----
rt_vars <- c("rt1", "rt2")  # adjust if needed
if (dependent_variable %in% rt_vars) {
cat("\n===== Robustness Check: LMM (lmer) =====\n")
library(lme4)
library(lmerTest)
library(emmeans)
lmm_mod <- lmer(
DV ~ repetition * context + (1 + repetition | subject),
data = combinedData_sub
)
# Compute and append effect sizes (from RM-ANOVA)
anova_tbl <- anova(aov_mod, es = c("pes","ges"))
simp <- as.data.frame(summary(simple_effects, infer = TRUE))
# n for paired comparison: df + 1 (works here because df=55 -> n=56)
simp$n  <- simp$df + 1
simp$dz <- simp$t.ratio / sqrt(simp$n)
simp[, c("repetition", "contrast", "estimate", "SE", "df", "t.ratio", "p.value", "dz")]
print(descriptives)
print(anova_tbl)
print(summary(lmm_mod))
print(anova(lmm_mod))
emm_lmm <- emmeans(lmm_mod, ~ repetition * context)
cat("\nPredicted means from LMM (original DV units):\n")
print(summary(emm_lmm, infer = TRUE))
cat("\nSimple effects from LMM (original units):\n")
print(contrast(emmeans(lmm_mod, ~ context | repetition),
method = "pairwise",
adjust = "holm") |> summary(infer = TRUE))
cat("\n===== End of Analysis =====\n")
} else {
cat("\n===== Robustness Check: Gamma GLMM (glmmTMB) =====\n")
library(glmmTMB)
library(emmeans)
combinedData_glmm <- combinedData_sub %>%
mutate(DV_pos = ifelse(DV <= 0, 1e-6, DV))
glmm_int <- glmmTMB(
DV_pos ~ repetition * context + (1 | subject),
data = combinedData_glmm,
family = Gamma(link = "log")
)
glmm_add <- glmmTMB(
DV_pos ~ repetition + context + (1 | subject),
data = combinedData_glmm,
family = Gamma(link = "log")
)
glmm_rep <- glmmTMB(
DV_pos ~ repetition + (1 | subject),
data = combinedData_glmm,
family = Gamma(link = "log")
)
# Compute and append effect sizes (from RM-ANOVA)
anova_tbl <- anova(aov_mod, es = c("pes","ges"))
simp <- as.data.frame(summary(simple_effects, infer = TRUE))
# n for paired comparison: df + 1 (works here because df=55 -> n=56)
simp$n  <- simp$df + 1
simp$dz <- simp$t.ratio / sqrt(simp$n)
simp[, c("repetition", "contrast", "estimate", "SE", "df", "t.ratio", "p.value", "dz")]
print(descriptives)
message("Subjects removed as outliers:")
print(bad_subjects)
print(anova_tbl)
print(summary(emm))
print(summary(simple_effects, infer = TRUE))
print(summary(glmm_int))
cat("\nLRT: Interaction vs Additive\n")
print(anova(glmm_add, glmm_int))
cat("\nLRT: Additive vs Repetition-only\n")
print(anova(glmm_rep, glmm_add))
emm_glmm <- emmeans(glmm_int, ~ repetition * context, type = "response")
cat("\nPredicted means from GLMM (original DV units):\n")
print(summary(emm_glmm))
cat("\nSimple effects from GLMM (original units):\n")
print(contrast(emm_glmm, method = "pairwise", by = "repetition"))
cat("\n===== End of Analysis =====\n")
}
